{
  "expo": {
    "name": "fitness-app-mobile",
    "slug": "fitness-app-mobile",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/07e2f44e-7d52-4753-b5e4-5dc7f74d42cb"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sobbani.fitnessappmobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Fitness AI to use the camera to auto-count reps during workouts.",
        "NSMotionUsageDescription": "Allow Fitness AI to read your step count to track daily activity.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sobbani.fitnessappmobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Fitness AI to access your photos to log meals.",
          "cameraPermission": "Allow Fitness AI to use the camera to photograph meals."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Fitness AI to use your location to tailor workout suggestions to the current weather."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Allow Fitness AI to use the camera to auto-count reps during workouts.",
          "enableMicrophonePermission": false,
          "enableCodeScanner": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "07e2f44e-7d52-4753-b5e4-5dc7f74d42cb"
      }
    },
    "owner": "sobbani16"
  }
}
